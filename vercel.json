{
  "functions": {
    "app/api/sync/order-line-items/route.js": { "maxDuration": 300 },
    "app/api/sync/all/route.js": { "maxDuration": 300 },
    "app/api/sync/b2b-orders/route.js": { "maxDuration": 300 },
    "app/api/sync/orders/route.js": { "maxDuration": 300 },
    "app/api/sync/companies/route.js": { "maxDuration": 300 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    }
  ]
}